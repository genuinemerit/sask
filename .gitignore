# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
dist/
build/
*.egg-info/
.venv/
venv/

# pytest-benchmark default storage (redirected to tests/results/perf/ — see tools/ops/run_perf.sh)
.benchmarks/

# Nix
result
result-*

# Locally-built Caddy binary (ansible/roles/caddy builds it via xcaddy on
# the controller, then copies it to the droplet — never commit the binary)
ansible/.build/

# Secrets — track only README.md and *.example (REQ-SEC-002)
secrets/*
!secrets/README.md
!secrets/*.example

# Editor
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# tools/helpers/make_tree.sh output
/tree.txt

# SPEC-036/DD-0023 page-builder scratch output: proper-noun-substituted,
# not-yet-translated es-ES drafts awaiting human review before promotion
# to docs/help/*.es-ES.md. Transient working files, not a reviewed artifact.
/docs/help_src/.drafts/
