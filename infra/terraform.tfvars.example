# Example tfvars file. Copy to terraform.tfvars to override defaults.
# terraform.tfvars is gitignored; never commit it.
#
# project_name            = "sask"
# region                  = "fra1"
# droplet_size            = "s-1vcpu-1gb"
# droplet_image           = "ubuntu-24-04-x64"
# ssh_public_key_path     = "~/.ssh/sask_ed25519.pub"
# ssh_private_key_path    = "~/.ssh/sask_ed25519"
# ssh_config_snippet_path = "~/.ssh/config.d/sask"
