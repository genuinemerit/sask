# Stub for future application-level secrets (DD-0014 decision #7). The
# deploy mechanism (Ansible copy + no_log + mode 0600) is wired up now so
# adding real auth later doesn't require re-architecting the deploy, but
# nothing here is read by the running application yet — auth is deferred,
# not designed out.

# Example shape for a future shared-secret/API-token scheme:
# [auth]
# shared_secret = "replace-with-a-real-secret-before-enabling-auth"
