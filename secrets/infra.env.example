# Copy to ~/.config/sask/infra.env (outside the repo) and fill in the real
# value. tools/ops/provision.sh and tools/ops/destroy.sh source this file
# before any DigitalOcean or droplet action; never commit the real file.
#
# DigitalOcean Personal Access Token (Settings -> API -> Tokens). Needs
# read/write access to: Droplets, SSH Keys, Reserved IPs, Domains, Firewalls.
export DIGITALOCEAN_TOKEN="dop_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
